# DanClaw Agent Runtime Dockerfile
# OpenClaw agent runtime with proper security, health checks, and environment variable handling

FROM node:20-alpine AS base

LABEL maintainer="DanLab <dev@danlab.dev>"
LABEL description="DanClaw AI Agent Runtime powered by OpenClaw"

# Install OpenClaw and Paperclip
RUN apk add --no-cache curl wget && \
    npm install -g @swarmclawai/swarmclaw paperclipai && \
    npm cache clean --force

WORKDIR /app

# Copy package files for agent runtime dependencies
COPY infra/docker/package.json ./package.json

# Install production dependencies only
RUN npm ci --only=production

# Copy application source (agent server)
COPY infra/docker/server.js ./server.js

# Create non-root user for security
RUN addgroup -g 1001 -S agentgroup && \
    adduser -u 1001 -S agentuser -G agentgroup && \
    chown -R agentuser:agentgroup /app

USER agentuser

# Health check using wget (available in alpine)
# PORT is passed as build arg for proper interpolation
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:8080/health || exit 1

EXPOSE 8080

ENV NODE_ENV=production
ENV PORT=8080

CMD ["node", "server.js"]
