# DanClaw Agent Runtime Dockerfile
# OpenClaw agent runtime with proper security, health checks, and environment variable handling

FROM node:20-alpine AS base

LABEL maintainer="DanLab <dev@danlab.dev>"
LABEL description="DanClaw AI Agent Runtime powered by OpenClaw"

# Install OpenClaw and Paperclip
RUN apk add --no-cache curl && \
    npm install -g @swarmclawai/swarmclaw && \
    npm install -g paperclipai && \
    npm cache clean --force

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install production dependencies only
RUN npm ci --only=production

# Copy application source
COPY . .

# Create non-root user for security
RUN addgroup -g 1001 -S agentgroup && \
    adduser -u 1001 -S agentuser -G agentgroup && \
    chown -R agentuser:agentgroup /app

USER agentuser

# Health check - verify port is listening
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD node -e "require('http').get('http://localhost:${PORT:-8080}/health', (r) => {process.exit(r.statusCode === 200 ? 0 : 1)})" || exit 1

EXPOSE 8080

ENV NODE_ENV=production
ENV PORT=8080

CMD ["node", "server.js"]