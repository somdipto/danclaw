# ===========================================
# DANCLAW — Environment Variables
# ===========================================
# Copy to .env.local (web) or .env (mobile)
# and fill in your InsForge + OpenRouter keys
# ===========================================

# ─── InsForge (Required) ───────────────────
# Get from: https://insforge.dev/dashboard/project/<id>/settings

# For web (Next.js)
NEXT_PUBLIC_INSFORGE_URL=https://your-project.insforge.dev
NEXT_PUBLIC_INSFORGE_ANON_KEY=ik_your_anon_key_here

# For mobile (Expo)
EXPO_PUBLIC_INSFORGE_URL=https://your-project.insforge.dev
EXPO_PUBLIC_INSFORGE_ANON_KEY=ik_your_anon_key_here

# ─── OpenRouter (Optional for free tier) ──
# Get from: https://openrouter.ai/credits
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-your_key_here

# ─── App URLs (for OAuth redirects) ────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
