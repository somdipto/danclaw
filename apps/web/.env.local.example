# InsForge Configuration
NEXT_PUBLIC_INSFORGE_URL=https://your-project.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=ik_your-key-here

# App URL (required for OAuth/deep links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenRouter Configuration
NEXT_PUBLIC_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenRouter Default Model (optional, defaults to qwen/qwen-3-6-plus)
# NEXT_PUBLIC_OPENROUTER_DEFAULT_MODEL=qwen/qwen-3-6-plus
