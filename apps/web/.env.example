# InsForge Configuration
NEXT_PUBLIC_INSFORGE_URL=https://<your-project-id>.<your-region>.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=<your-anon-key-from-insforge-dashboard>

# OpenRouter (Optional - users can bring their own)
NEXT_PUBLIC_OPENROUTER_KEY=<your-openrouter-key>
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4
