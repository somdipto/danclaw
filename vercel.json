{
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @danclaw/web build",
  "devCommand": "pnpm --filter @danclaw/web dev",
  "installCommand": "pnpm install",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_INSFORGE_URL": "@insforge-url",
    "NEXT_PUBLIC_INSFORGE_ANON_KEY": "@insforge-anon-key"
  },
  "secrets": [
    "insforge-url",
    "insforge-anon-key"
  ]
}
